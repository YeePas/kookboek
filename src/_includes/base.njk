<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if title %}{{ title }} — {% endif %}Foodnotes</title>
<link rel="stylesheet" href="{{ '/style.css' | url }}">
</head>
<body>
{% include "partials/nav.njk" %}
{{ content | safe }}
<script>
document.querySelectorAll('.photo-carousel').forEach(c => {
  const items = c.querySelectorAll('.carousel-item');
  if (items.length < 2) return;

  let track = c.querySelector('.carousel-track');
  if (!track) {
    track = document.createElement('div');
    track.className = 'carousel-track';
    items.forEach(item => track.appendChild(item));
    c.insertBefore(track, c.firstChild);
  }

  let cur = 0;
  const counter = c.querySelector('.carousel-counter');
  const nextBtn = c.querySelector('.next');
  const prevBtn = c.querySelector('.prev');
  const show = i => {
    cur = (i + items.length) % items.length;
    const peekCurrent = parseFloat(getComputedStyle(c).getPropertyValue('--peek-current')) || 80;
    track.style.transform = 'translateX(-' + (cur * peekCurrent) + '%)';
    items.forEach((el, index) => el.classList.toggle('is-active', index === cur));
    if (counter) counter.textContent = (cur + 1) + ' / ' + items.length;
  };

  show(0);

  if (prevBtn) {
    prevBtn.addEventListener('click', () => show(cur - 1));
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', () => show(cur + 1));
  }
});
</script>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>