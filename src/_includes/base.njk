<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if title %}{{ title }} — {% endif %}Foodnotes</title>
<link rel="stylesheet" href="{{ '/style.css' | url }}">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
{% include "partials/nav.njk" %}
{{ content | safe }}
<script>
// ── Recept schalen ──────────────────────────────────────────────────────
(function () {
  const meta = document.querySelector('.recipe-meta[data-base-servings]');
  if (!meta) return;

  const base = parseFloat(meta.dataset.baseServings);
  if (!base || isNaN(base)) return;

  let current = base;
  const counter   = meta.querySelector('.stepper-count');
  const minusBtn  = meta.querySelector('.stepper-minus');
  const plusBtn   = meta.querySelector('.stepper-plus');
  const items     = document.querySelectorAll('li[data-ingredient]');

  // Unicode fraction map → decimal
  const FRAC_TO_DEC = { '½': 0.5, '⅓': 1/3, '⅔': 2/3, '¼': 0.25, '¾': 0.75,
                        '⅕': 0.2, '⅖': 0.4, '⅗': 0.6, '⅘': 0.8,
                        '⅙': 1/6, '⅚': 5/6, '⅛': 0.125, '⅜': 0.375,
                        '⅝': 0.625, '⅞': 0.875 };

  // Parse a string like "1½", "½", "3", "2.5"  → number | null
  function parseAmount(str) {
    str = str.trim();
    // Unicode frac only, e.g. "½"
    if (FRAC_TO_DEC[str] !== undefined) return FRAC_TO_DEC[str];
    // Integer or decimal, e.g. "3", "2.5", "1,5"
    const plain = parseFloat(str.replace(',', '.'));
    if (!isNaN(plain)) {
      // Check for trailing unicode frac, e.g. "1½"
      const lastChar = str[str.length - 1];
      if (FRAC_TO_DEC[lastChar] !== undefined) return Math.floor(plain) + FRAC_TO_DEC[lastChar];
      return plain;
    }
    return null;
  }

  // Format a decimal to a clean "1.5" string (round to 1 decimal, trim .0)
  function fmt(n) {
    const rounded = Math.round(n * 10) / 10;
    return Number.isInteger(rounded) ? String(rounded) : rounded.toFixed(1).replace('.', ',');
  }

  // Token regex: optional leading integer + optional unicode frac, or plain number
  const TOKEN_RE = /(\d+[.,]?\d*|\d*[½⅓⅔¼¾⅕⅖⅗⅘⅙⅚⅛⅜⅝⅞]|[½⅓⅔¼¾⅕⅖⅗⅘⅙⅚⅛⅜⅝⅞])/;

  function scaleText(original, ratio) {
    // Don't scale lines that look like percentages or lack a leading number
    if (/\d\s*%/.test(original)) return original;

    // Find and replace the FIRST quantity token in the string
    return original.replace(TOKEN_RE, (match) => {
      const val = parseAmount(match);
      if (val === null) return match;
      return fmt(val * ratio);
    });
  }

  function render() {
    const ratio = current / base;
    counter.textContent = current;
    minusBtn.disabled = current <= 1;

    items.forEach(li => {
      const orig = li.dataset.ingredient;
      li.textContent = ratio === 1 ? orig : scaleText(orig, ratio);
    });
  }

  minusBtn.addEventListener('click', () => { if (current > 1) { current--; render(); } });
  plusBtn.addEventListener('click',  () => { current++; render(); });

  render();
})();

// ── Foto carousel ───────────────────────────────────────────────────────
document.querySelectorAll('.photo-carousel').forEach(c => {
  const items = c.querySelectorAll('.carousel-item');
  if (items.length < 2) return;

  let track = c.querySelector('.carousel-track');
  if (!track) {
    track = document.createElement('div');
    track.className = 'carousel-track';
    items.forEach(item => track.appendChild(item));
    c.insertBefore(track, c.firstChild);
  }

  let cur = 0;
  const counter = c.querySelector('.carousel-counter');
  const nextBtn = c.querySelector('.next');
  const prevBtn = c.querySelector('.prev');
  const show = i => {
    cur = (i + items.length) % items.length;
    const peekCurrent = parseFloat(getComputedStyle(c).getPropertyValue('--peek-current')) || 80;
    track.style.transform = 'translateX(-' + (cur * peekCurrent) + '%)';
    items.forEach((el, index) => el.classList.toggle('is-active', index === cur));
    if (counter) counter.textContent = (cur + 1) + ' / ' + items.length;
  };

  show(0);

  if (prevBtn) {
    prevBtn.addEventListener('click', () => show(cur - 1));
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', () => show(cur + 1));
  }

  // Touch / swipe support
  let touchStartX = 0;
  c.addEventListener('touchstart', e => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  c.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) show(dx < 0 ? cur + 1 : cur - 1);
  }, { passive: true });
});

// ── Ontdek: shuffle & filter ────────────────────────────────────────────
(function() {
  var grid = document.getElementById('ontdek-grid');
  if (!grid) return;

  // Fisher-Yates shuffle
  var cards = Array.from(grid.children);
  for (var i = cards.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var tmp = cards[i]; cards[i] = cards[j]; cards[j] = tmp;
  }
  cards.forEach(function(c) { grid.appendChild(c); });

  // Category filter
  document.querySelectorAll('.filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var cat = btn.dataset.cat;
      grid.querySelectorAll('.toc-card').forEach(function(card) {
        card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
      });
    });
  });
})();
</script>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", user => {
      if (!user) {
        window.netlifyIdentity.on("login", () => {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
{% if site.cloudflareWebAnalyticsToken %}
<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token":"{{ site.cloudflareWebAnalyticsToken }}"}'></script>
{% endif %}
</body>
</html>