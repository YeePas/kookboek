---
layout: base.njk
title: ""
bodyClass: home
---
<div class="cover">
  <h1>Foodnotes</h1>
  <div class="divider"></div>
  {% if site.showOntdek %}
  <a class="sub" href="#ontdek">{{ collections.recepten | length }} recepten</a>
  <div class="scroll-hint">
    <span>Ontdek</span>
    <span class="scroll-arrow">&darr;</span>
  </div>
  {% else %}
  <div class="sub">{{ collections.recepten | length }} recepten</div>
  {% endif %}
</div>
{% if site.showOntdek %}
<section class="ontdek" id="ontdek">
  <div class="ontdek-header">
    <h2>Ontdek</h2>
    <div class="ontdek-filters">
      <button class="filter-btn active" data-cat="all">Alles</button>
      {% for cat in categories | sortedCategories %}
      {% set catRecipes = collections.recepten | byCategory(cat.slug) %}
      {% if catRecipes.length > 0 %}
      <button class="filter-btn" data-cat="{{ cat.slug }}">{{ cat.title }}</button>
      {% endif %}
      {% endfor %}
    </div>
  </div>
  <div class="ontdek-grid" id="ontdek-grid">
    {% for recipe in collections.recepten %}
    <a class="toc-card" href="{{ recipe.url | url }}" data-category="{{ recipe.data.category }}">
      {% if site.showOntdekFotos and recipe.data.foto %}
      {% responsiveImage '/fotos/' + (recipe.data.foto | cmsImagePath), recipe.data.title, '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw', '', '360,720,1080', 'lazy' %}
      {% endif %}
      <div class="card-body">
        <div class="card-category">{{ recipe.data.category | categoryTitle }}</div>
        <div class="card-title">{{ recipe.data.title }}</div>
        <div class="card-desc">{{ recipe.data.subtitle | truncate(80) }}</div>
      </div>
    </a>
    {% endfor %}
  </div>
  <div class="ontdek-more-wrap">
    <button id="ontdek-load-more" class="ontdek-load-more" type="button">Laad meer recepten</button>
  </div>
</section>
{% endif %}
